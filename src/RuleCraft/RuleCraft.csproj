<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>RuleCraft</RootNamespace>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>RuleCraft</PackageId>
    <Version>1.0.1</Version> <!-- x-release-please-version -->
    <Authors>mkasperczyk90@gmail.com</Authors>
    <Description>Runtime rule engine whose implementations are generated by an LLM, verified, human-approved and hot-loaded into the running application.</Description>
    <PackageTags>rules;rule-engine;llm;ai;roslyn;codegen;business-rules;hot-reload</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageProjectUrl>https://github.com/mkasperczyk90/RuleCraft</PackageProjectUrl>
    <RepositoryUrl>https://github.com/mkasperczyk90/RuleCraft</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <!-- Source stepping. SourceLink needs no PackageReference: the .NET SDK has shipped it in-box
       since 8.0 and wires up the GitHub host from the origin remote. PublishRepositoryUrl puts the
       commit hash in the nuspec, so a symbol from this package resolves to the exact source that
       built it. Release builds in CI must also set ContinuousIntegrationBuild=true. -->
  <PropertyGroup>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
  </PropertyGroup>

  <PropertyGroup>
    <!-- Consumers read this API through IntelliSense; the docs are half the design. -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- CS1591 (missing XML comment): the types worth explaining carry docs, and demanding one on
         every enum member and record property buys "Gets the Id." noise, not understanding. -->
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\LICENSE" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="RuleCraft.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.6.0" />
    <PackageReference Include="Microsoft.Extensions.AI.Abstractions" Version="10.8.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.10" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.10" />
  </ItemGroup>

</Project>
